{
  "rules": {
    "stats": {
      "totalProfiles": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    "admin_users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": false
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "profiles": {
      "$profileId": {
        ".read": "auth != null || (data.child('status').val() == 'active' && data.child('publicProfile').val() != false)",
        ".write": "auth != null && ((!data.exists() && newData.child('ownerUserId').val() == auth.uid) || (data.exists() && data.child('ownerUserId').val() == auth.uid))"
      }
    },
    "profiles_by_owner": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    }
  }
}
